# Production environment — values here are committed as non-secret defaults.
# Sensitive overrides (API keys, Sentry DSN) must be set in the Vercel
# project's Environment Variables dashboard, NOT in this file.

VITE_APP_API_URL=https://flatledger-api.onrender.com
VITE_ADMIN_API_URL=https://flatledger-api.onrender.com
VITE_APP_ENV=production

# Sentry error tracking — set the real DSN in Vercel environment variables
# VITE_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
