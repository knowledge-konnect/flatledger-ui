# Development overrides — Vite proxy routes /api to the real backend server-side,
# so the browser makes same-origin requests and CORS is never triggered.
VITE_APP_API_URL=https://localhost:7110
VITE_ADMIN_API_URL=https://localhost:7110
VITE_APP_ENV=development

# Vite dev proxy target — proxies /api requests server-side to avoid CORS
VITE_DEV_PROXY_TARGET=https://localhost:7110
