# API Configuration
# Set VITE_APP_API_URL to your backend server root URL
# The API client will append endpoint paths like /auth/register, /users, etc.
# Example: https://localhost:7110 or https://api.yourdomain.com
VITE_APP_API_URL=https://localhost:7110

# Legacy API Base URL (if using src/lib/api.ts - not recommended)
# VITE_API_BASE_URL=http://localhost:3000/api

# Dev proxy target — Vite will forward /api requests to this URL in development.
# Avoids hardcoding the production URL in vite.config.ts.
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Support WhatsApp number (used on LandingPage support button)
# Format: country code + number, no spaces or dashes. E.g. 919876543210
VITE_SUPPORT_WHATSAPP=919999999999

# Environment
VITE_APP_ENV=development
